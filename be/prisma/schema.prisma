generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"             // Sử dụng PostgreSQL làm database
}
model Admin {
  id       String @id                 // ID tự gán, có thể sửa trong Studio
  userName String @unique             // Tên đăng nhập, duy nhất
}

model Student {
  id          String   @id            // ID tự gán
  studentCode String   @unique        // Mã số học sinh
  userName    String   @unique        // Tên đăng nhập
  name        String                  // Tên
  surname     String                  // Họ
  dateOfBirth DateTime                // Ngày sinh
  email       String?  @unique        // Email (có thể null)
  phone       String?  @unique        // SĐT (có thể null)
  address     String                  // Địa chỉ
  img         String?                 // Ảnh đại diện
  bloodType   String                  // Nhóm máu
  sex         UserSex                 // Giới tính (enum)
  status      String   @default("active") // Tình trạng học tập
  createdAt   DateTime @default(now())    // Ngày tạo hồ sơ

  parentId    String                  // Liên kết phụ huynh
  parent      Parent?  @relation(fields: [parentId], references: [id])
  classId     Int                     // Liên kết lớp
  class       Class    @relation(fields: [classId], references: [id])
  gradeId     Int                     // Liên kết khối
  grade       Grade    @relation(fields: [gradeId], references: [id])

  attendances Attendance[]            // Điểm danh
  results     Result[]                 // Kết quả học tập
}

model Teacher {
  id        String   @id              // ID tự gán
  userName  String   @unique          // Tên đăng nhập
  name      String
  surname   String
  email     String?  @unique
  phone     String?  @unique
  address   String
  img       String?
  bloodType String
  sex       UserSex
  majorSubject String?                // Môn chuyên ngành
  dateOfBirth DateTime?
  createdAt DateTime @default(now())

  subjects  Subject[]                 // Môn dạy
  lessons   Lesson[]                  // Bài giảng
  classes   Class[]                   // Lớp phụ trách
}

model Parent {
  id        String   @id              // ID tự gán
  userName  String   @unique
  name      String
  surname   String
  relation  String                    // Cha/Mẹ
  email     String?  @unique
  phone     String   @unique
  address   String
  occupation String?                  // Nghề nghiệp
  img       String?
  dateOfBirth DateTime?
  createdAt DateTime @default(now())

  students  Student[]                 // Danh sách con
}

model Grade {
  id    Int @id @default(autoincrement()) // ID khối (auto tăng)
  level Int @unique                       // Khối (ví dụ: 6,7,8,9)

  students Student[]
  classes  Class[]
}

model Class {
  id       Int    @id @default(autoincrement()) // ID lớp (auto tăng)
  name     String @unique                       // Tên lớp
  capacity Int                                  // Sĩ số

  supervisorId  String?                         // Giáo viên chủ nhiệm
  supervisor    Teacher? @relation(fields: [supervisorId], references: [id])
  lessons       Lesson[]
  students      Student[]
  gradeId       Int
  grade         Grade @relation(fields: [gradeId], references: [id])
  announcements Announcement[]
  events        Event[]
}

model Subject {
  id       Int    @id @default(autoincrement()) // ID môn học (auto tăng)
  name     String @unique                       // Tên môn
  teachers Teacher[]
  lessons  Lesson[]
}

model Lesson {
  id        Int    @id @default(autoincrement()) // ID bài giảng
  name      String
  day       Day
  startTime DateTime
  endTime   DateTime

  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id])
  classId   Int
  class     Class   @relation(fields: [classId], references: [id])
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  exams     Exam[]
  assignments Assignment[]
  attendances Attendance[]
}

model Exam {
  id        Int    @id @default(autoincrement()) // ID bài kiểm tra
  title     String
  startTime DateTime
  endTime   DateTime

  lessonId Int
  lesson   Lesson @relation(fields: [lessonId], references: [id])
  results  Result[]
}

model Assignment {
  id        Int    @id @default(autoincrement()) // ID bài tập
  title     String
  startDate DateTime
  dueDate   DateTime

  lessonId  Int
  lesson    Lesson @relation(fields: [lessonId], references: [id])
  results   Result[]
}

model Result {
  id    Int @id @default(autoincrement())        // ID kết quả
  score Int

  examId Int?
  exam   Exam? @relation(fields: [examId], references: [id])

  assignmentId Int?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
}

model Attendance {
  id      Int @id @default(autoincrement())      // ID điểm danh
  date    DateTime
  present Boolean

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  lessonId Int
  lesson   Lesson @relation(fields: [lessonId], references: [id])
}

model Event {
  id          Int    @id @default(autoincrement()) // ID sự kiện
  title       String
  description String
  startTime   DateTime
  endTime     DateTime

  classId Int?
  class   Class? @relation(fields: [classId], references: [id])
}

model Announcement {
  id          Int    @id @default(autoincrement()) // ID thông báo
  title       String
  description String
  date        DateTime

  classId Int?
  class   Class? @relation(fields: [classId], references: [id])
}

enum UserSex {
  MALE    // Nam
  FEMALE  // Nữ
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}
