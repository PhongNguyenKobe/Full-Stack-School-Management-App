generator client {
  provider = "prisma-client"          // Tạo Prisma Client để dùng trong code
  output   = "../src/generated/prisma" // Nơi sinh ra client
}

datasource db {
  provider = "postgresql"             // Sử dụng PostgreSQL làm database
}

model Admin {
  id       String @id @default(uuid()) // Định danh duy nhất
  userName String @unique              // Tên đăng nhập, không trùng
}

model Student {
  id          String   @id @default(uuid()) // ID duy nhất
  studentCode String   @unique              // Mã số học sinh
  userName    String   @unique              // Tên đăng nhập
  name        String                          // Tên
  surname     String                          // Họ
  dateOfBirth DateTime                        // Ngày sinh
  email       String?  @unique                // Email (có thể null)
  phone       String?  @unique                // SĐT (có thể null)
  address     String                          // Địa chỉ
  img         String?                         // Ảnh đại diện
  bloodType   String                          // Nhóm máu
  sex         UserSex                         // Giới tính (enum)
  status      String   @default("active")     // Tình trạng học tập
  createdAt   DateTime @default(now())        // Ngày tạo hồ sơ

  parentId    String                           // Liên kết phụ huynh
  parent      Parent?  @relation(fields: [parentId], references: [id])
  classId     Int                              // Liên kết lớp
  class       Class    @relation(fields: [classId], references: [id])
  gradeId     Int                              // Liên kết khối
  grade       Grade    @relation(fields: [gradeId], references: [id])

  attendances Attendance[]                     // Điểm danh
  results     Result[]                         // Kết quả học tập
}

model Teacher {
  id        String    @id @default(uuid())     // ID duy nhất
  userName  String    @unique                  // Tên đăng nhập
  name      String                             
  surname   String                             
  email     String?   @unique                  
  phone     String?   @unique                  
  address   String                             
  img       String?                            
  bloodType String                             
  sex       UserSex                            
  majorSubject String?                         // Môn chuyên ngành
  createdAt DateTime  @default(now())          

  subjects  Subject[]                          // Môn dạy
  lessons   Lesson[]                           // Bài giảng
  classes   Class[]                            // Lớp phụ trách
}

model Parent {
  id        String    @id @default(uuid())     // ID duy nhất
  userName  String    @unique                  
  name      String                             
  surname   String                             
  relation  String    // Cha/Mẹ                 
  email     String?   @unique                  
  phone     String    @unique                  
  address   String                             
  occupation String?  // Nghề nghiệp           
  img       String?                            
  createdAt DateTime  @default(now())          

  students  Student[]                          // Danh sách con
}

model Grade {
  id    Int @id @default(autoincrement())      // ID khối
  level Int @unique                            // Khối (ví dụ: 10, 11, 12)

  students Student[]                           // Học sinh trong khối
  classes  Class[]                             // Lớp trong khối
}

model Class {
  id       Int    @id @default(autoincrement()) // ID lớp
  name     String @unique                       // Tên lớp
  capacity Int                                  // Sĩ số

  supervisorId  String?                          // Giáo viên chủ nhiệm
  supervisor    Teacher? @relation(fields: [supervisorId], references: [id])
  lessons       Lesson[]                        // Bài giảng
  students      Student[]                       // Học sinh
  gradeId       Int                             // Khối
  grade         Grade @relation(fields: [gradeId], references: [id])
  announcements Announcement[]                  // Thông báo
  events        Event[]                         // Sự kiện
}

model Subject {
  id       Int       @id @default(autoincrement()) // ID môn học
  name     String    @unique                       // Tên môn
  teachers Teacher[]                               // Giáo viên dạy
  lessons  Lesson[]                                // Bài giảng
}

model Lesson {
  id        Int      @id @default(autoincrement()) // ID bài giảng
  name      String                                 // Tên bài
  day       Day                                    // Ngày học
  startTime DateTime                               // Giờ bắt đầu
  endTime   DateTime                               // Giờ kết thúc

  subjectId   Int
  subject     Subject @relation(fields: [subjectId], references: [id])
  classId     Int
  class       Class   @relation(fields: [classId], references: [id])
  teacherId   String
  teacher     Teacher @relation(fields: [teacherId], references: [id])
  exams       Exam[]                               // Bài kiểm tra
  assignments Assignment[]                         // Bài tập
  attendances Attendance[]                         // Điểm danh
}

model Exam {
  id        Int      @id @default(autoincrement()) // ID bài kiểm tra
  title     String                                 // Tiêu đề
  startTime DateTime                               // Bắt đầu
  endTime   DateTime                               // Kết thúc

  lessonId Int
  lesson   Lesson @relation(fields: [lessonId], references: [id])
  results  Result[]                                // Kết quả
}

model Assignment {
  id        Int      @id @default(autoincrement()) // ID bài tập
  title     String                                 // Tiêu đề
  startDate DateTime                               // Ngày giao
  dueDate   DateTime                               // Hạn nộp

  lessonId  Int
  lesson    Lesson @relation(fields: [lessonId], references: [id])
  results   Result[]                               // Kết quả
}

model Result {
  id    Int @id @default(autoincrement())          // ID kết quả
  score Int                                        // Điểm số

  examId Int?
  exam   Exam? @relation(fields: [examId], references: [id])

  assignmentId Int?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
}

model Attendance {
  id      Int      @id @default(autoincrement())   // ID điểm danh
  date    DateTime                                // Ngày
  present Boolean                                 // Có mặt hay không

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  lessonId Int
  lesson   Lesson @relation(fields: [lessonId], references: [id])
}

model Event {
  id          Int      @id @default(autoincrement()) // ID sự kiện
  title       String                                 // Tiêu đề
  description String                                 // Mô tả
  startTime   DateTime                               // Bắt đầu
  endTime     DateTime                               // Kết thúc

  classId Int?
  class   Class? @relation(fields: [classId], references: [id])
}

model Announcement {
  id          Int      @id @default(autoincrement()) // ID thông báo
  title       String                                 // Tiêu đề
  description String                                 // Nội dung
  date        DateTime                               // Ngày thông báo

  classId Int?
  class   Class? @relation(fields: [classId], references: [id])
}

enum UserSex {
  MALE    // Nam
  FEMALE  // Nữ
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

